n = 100
p = 5
beta0 = rep(1,p)
x = matrix(rnorm(n * p), n, p)
T = exp(x%*%beta0 + rnorm(n))
C = rexp(n, rate = exp(-2))
d = 1*(T<C)
y = pmin(T,C)
dt = data.frame(y,d,x)
fit <- aftpen(dt, lambda = 0.1, se = "CF", type = "BAR")
library(aftPenCDA)
fit <- aftpen(dt, lambda = 0.1, se = "CF", type = "BAR")
fit$beta
fit <- aftpen(dt, lambda = 0.01, se = "CF", type = "BAR")
fit$beta
