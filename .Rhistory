random_sample = function(seed, n, p, Cendis, Cenrates,beta0){
set.seed(seed)
n = n
p = p
x = matrix(rnorm(n*p), ncol=p) # random sample
if(Cendis == "exp") T = exp(x%*%beta0 + log(rexp(n)))
if(Cendis == "norm") T = exp(x%*%beta0 + rnorm(n))
C = rexp(n, rate = exp(Cenrates))
d = 1*(T<C)
mean(d)
y = pmin(T,C)
return(dt = data.frame(y,d,x))
}
n = 300 ; p = 10
beta0 = c(0,0,0,0,1,0,1,1,0,0)
dt=random_sample(1, n, p, 'exp',-2,beta0)
aftPenCDA(dt, 0.2, se='CF',type='BAR')
