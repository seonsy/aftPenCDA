which.min(unlist(fit[3,]))
fit[,which.min(unlist(fit[3,]))]
unlist(fit[3,])
normfun = function(a,x=NULL) {
if (is.null(x)) covx = diag(length(a))
if (!is.null(x)) covx = cov(x)
res = a / sqrt(drop(a%*%covx%*%a))
# if (sum(res) == 0) res = a
return(res)
}
library(quantreg)
n=150
p = 1
beta0 = sort(sample(c(-3,1,3),n,replace = TRUE))
truepar = normfun(unique(beta0))
X = rnorm(n)
Y = X*beta0 + rnorm(n)
delta = rep(1,n)
smrc = function(Y, X, delta,z=NULL,lambda=0) {
options(warn = -1)
n = length(Y)
if (is.null(z)) z = rep(1,n)
# n = nrow(X); p = ncol(X)
id_i = rep(1:n, each = n)
id_j = rep(1:n, times = n)
X = diag(n)*X
di = delta[id_i]
zi = rep(z,each=n)
Yi = Y[id_i]
Yj = Y[id_j]
Xij = as.matrix(X[id_i,] - X[id_j,])
wji = di*I(Yj>Yi)
yy = c(rep(0,n^2), 1e10)
xx = rbind(Xij*zi, -crossprod(wji,Xij))
ww = c(wji/n, 1)
D = -diff((diag(n)), diff = 1)*0.01
xtilde = as.matrix.csr(rbind(xx, D))
ytilde = c(yy,rep(0,nrow(D)))
wtilde = c(ww,rep(1,nrow(D)))
oldpar = normfun(round(rq.wfit(x=xtilde,y=ytilde,weights=wtilde,method = "sfn")$coef,8))
niter = 0; err = 10
if (lambda > 0) {
D = -diff((diag(n)), diff = 1)
ytilde = c(yy,rep(0,nrow(D)))
wtilde = c(ww,rep(1,nrow(D)))
val = abs(drop(D%*%oldpar))
r =3.7
oldpderiv = ifelse(abs(val) <= lambda, lambda, pmax(lambda*r - abs(val), 0)/(r-1))
while (err > 1e-2 & niter < 20) {
pen = D*oldpderiv
xtilde = as.matrix.csr(rbind(xx, pen))
(newpar = normfun(rq.wfit(x=xtilde,y=ytilde,weights=wtilde,method = "sfn")$coef))
val = abs(drop(D%*%newpar))
newpderiv = ifelse(abs(val) <= lambda, lambda, pmax(lambda*r - abs(val), 0)/(r-1))
err = sum((newpderiv - oldpderiv)^2)
oldpar = newpar
niter = niter + 1
}
}
oldpar = round(oldpar, 8)
est = normfun(unique(oldpar))
grpid = rep(seq_along(unique(oldpar)), table(oldpar))
# xpar = drop(X*rep(est,table(grpid)))
xpar = drop(X*normfun(oldpar))
xparij = xpar[id_i] - xpar[id_j]
n2=n*(n-1)
logobj = drop(-log(pmax(wji%*%(abs(xparij)*(xparij<0))/n2,1e-5)) )
# logobj = drop(log(ww%*%abs(yy-xx%*%oldpar)/length(yy)))
#
# c0 = log(log(n))*log(n)/n
c0 = log(n)/n
bic = logobj + (max(grpid))*c0
list(est = est, grpid = grpid, bic = bic, numgrp = max(grpid))
}
(fit = sapply(seq(0,50,len=20), function(a) smrc(Y,X,delta = rep(1,n), lambda=a)))
which.min(unlist(fit[3,]))
fit[,which.min(unlist(fit[3,]))]
unlist(fit[3,])
