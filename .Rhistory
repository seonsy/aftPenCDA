library(survival)
library(MASS)
library(trust)
head(gehan)
y=with(gehan,list(x=time,delta=cens))
Z=with(gehan,model.matrix(~treat))[,-1]
Z=as.matrix(Z)
beta=coxph(Surv(time,cens)~treat,gehan)$coef
y=list(x=1:6,delta=rep(1,6))
Z=as.matrix(rep(0:1,3))
beta=0
partlik=function(beta,y,Z){
eta=c(Z%*%beta)
at.risk=outer(y$x,y$x,"<=")
at.sum=c(at.risk%*%exp(eta))
loglik=sum( y$delta*(eta-log(at.sum)))
pi=outer(exp(eta),at.sum,"/")
pi.mat=at.risk*t(pi)
Z.bar=pi.mat%*%Z
score=colSums((Z-Z.bar)*y$delta)
W=-t(pi.mat)%*%diag(y$delta)%*%pi.mat
diag(W)=diag(t(pi.mat)%*%diag(y$delta)%*%(1-pi.mat))
inform=t(Z)%*%W%*%Z
list(value=loglik,gradient=score,hessian=inform)
}
trust(partlik,beta/10,1,10,y=y,Z=Z,minimize=FALSE)
